        <li>M · E · R · O · H · O → <span class="minihueco"></span></li>
        <li>G · O · R · I · E · G → <span class="minihueco"></span></li>
        <li>T · E · G · I · N · A · G → <span class="minihueco"></span></li>
      </ul>
