          <ul><li>ice</li><li>hunter</li><li>frozen</li><li>arrow</li><li>bow</li><li>copper</li><li>axe</li><li>mountain</li></ul>
          <ul><li>cazador</li><li>flecha</li><li>hielo</li><li>montaña</li><li>congelado</li><li>arco</li><li>hacha</li><li>cobre</li></ul>
